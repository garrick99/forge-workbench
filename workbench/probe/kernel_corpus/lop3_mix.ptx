// Real-world shape: bitwise mix that ptxas typically merges into a
// single LOP3 instruction via its bit-table optimizer.  Our codegen
// covers LOP3, but this is exactly the pattern where ptxas's peephole
// catalog has historically been ahead of ours.  Each thread XORs the
// majority mix with its tid so the output is deterministic.
.version 8.0
.target sm_120
.address_size 64
.visible .entry probe(.param .u64 p_out, .param .u32 n)
{
    .reg .u32 %r<8>;
    .reg .u64 %rd<4>;
    .reg .pred %p0;

    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;

    mov.u32 %r2, 0xCAFEBABE;
    mov.u32 %r3, 0x12345678;
    mov.u32 %r4, 0xDEADBEEF;

    // Majority(a, b, c) = (a & b) | (b & c) | (c & a)
    // Followed by XOR-with-a, which is the LOP3 truth-table 0x96.
    and.b32 %r5, %r2, %r3;
    and.b32 %r6, %r3, %r4;
    or.b32  %r5, %r5, %r6;
    and.b32 %r6, %r4, %r2;
    or.b32  %r5, %r5, %r6;
    xor.b32 %r5, %r5, %r2;
    xor.b32 %r5, %r5, %r0;

    ld.param.u64 %rd0, [p_out];
    mul.wide.u32 %rd1, %r0, 4;
    add.u64 %rd2, %rd0, %rd1;
    cvta.to.global.u64 %rd2, %rd2;
    st.global.u32 [%rd2], %r5;
    ret;
}

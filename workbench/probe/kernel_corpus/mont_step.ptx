// Real-world shape: one limb of multi-precision multiply with carry,
// then M31 (2^31 - 1) field reduction.  This is the inner kernel of
// VortexSTARK's hot path (FRI fold, NTT, barycentric eval) and tests
// the mul.hi + add.cc + addc carry-chain encoding plus the trailing
// reduction's shr/mask/add fusion.
.version 8.0
.target sm_120
.address_size 64
.visible .entry probe(.param .u64 p_out, .param .u32 n)
{
    .reg .u32 %t0, %nv, %a, %b, %lo, %hi, %r;
    .reg .u64 %p, %off, %pg;
    .reg .pred %guard;

    mov.u32 %t0, %tid.x;
    ld.param.u32 %nv, [n];
    setp.ge.u32 %guard, %t0, %nv;
    @%guard ret;

    add.u32 %a, %t0, 1;
    mov.u32 %b, 0xDEADBEEF;
    mul.lo.u32 %lo, %a, %b;
    mul.hi.u32 %hi, %a, %b;
    add.cc.u32 %lo, %lo, 0x12345678;
    addc.u32   %hi, %hi, 0;

    // Mod (2^31 - 1) reduction, two passes to settle the carry from
    // the first reduction (typical M31 reduction pattern).
    and.b32 %r,  %lo, 0x7FFFFFFF;
    shr.b32 %lo, %lo, 31;
    add.u32 %r,  %r,  %lo;
    and.b32 %lo, %r,  0x7FFFFFFF;
    shr.b32 %r,  %r,  31;
    add.u32 %r,  %r,  %lo;

    ld.param.u64 %p, [p_out];
    mul.wide.u32 %off, %t0, 4;
    add.u64 %pg, %p, %off;
    cvta.to.global.u64 %pg, %pg;
    st.global.u32 [%pg], %r;
    ret;
}

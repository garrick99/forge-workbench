// Real-world shape: shared-memory atomic add — common in reduction
// patterns (per-block accumulation before global flush).  Forge emits
// atom.shared.add for circle_ntt_batch's per-CTA tally; openptxas's
// atom-shared family is a known under-tested surface.
.version 9.0
.target sm_120
.address_size 64
.visible .entry probe(.param .u64 p_out, .param .u32 n)
{
    .shared .u32 acc[1];

    .reg .u32 %r<6>;
    .reg .u64 %rd<4>;
    .reg .pred %p0;

    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;

    // Lane 0 zeroes the shared accumulator; barrier; everyone adds tid+1
    setp.eq.u32 %p0, %r0, 0;
    @%p0 st.shared.u32 [acc], 0;
    bar.sync 0;

    add.u32 %r2, %r0, 1;
    atom.shared.add.u32 %r3, [acc], %r2;
    bar.sync 0;

    // Each lane writes (its previous-value XOR its tid) so the result
    // is a deterministic function of which order the atom resolved.
    xor.b32 %r4, %r3, %r0;

    ld.param.u64 %rd0, [p_out];
    mul.wide.u32 %rd1, %r0, 4;
    add.u64     %rd0, %rd0, %rd1;
    cvta.to.global.u64 %rd0, %rd0;
    st.global.u32 [%rd0], %r4;
    ret;
}

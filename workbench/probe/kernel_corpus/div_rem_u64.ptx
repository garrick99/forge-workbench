// Real-world shape: 64-bit divide + remainder.  Used in Forge's
// emitted reduce_words_to_m31 (the .ptx output the mower compares).
// openptxas currently logs `unimplemented PTX instruction: rem u64`
// on every Forge cycle — this kernel surfaces it through the corpus
// axis so it gets a probe row instead of just a stderr warning.
.version 9.0
.target sm_120
.address_size 64
.visible .entry probe(.param .u64 p_out, .param .u32 n)
{
    .reg .u32 %r<4>;
    .reg .u64 %rd<8>;
    .reg .pred %p0;

    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;

    cvt.u64.u32 %rd1, %r0;
    add.u64     %rd1, %rd1, 1;             // dividend = tid + 1
    mov.u64     %rd2, 0x123456789abcdef;   // divisor (fixed prime-ish)
    div.u64     %rd3, %rd1, %rd2;
    rem.u64     %rd4, %rd1, %rd2;
    add.u64     %rd5, %rd3, %rd4;
    cvt.u32.u64 %r2, %rd5;

    ld.param.u64 %rd6, [p_out];
    mul.wide.u32 %rd7, %r0, 4;
    add.u64     %rd6, %rd6, %rd7;
    cvta.to.global.u64 %rd6, %rd6;
    st.global.u32 [%rd6], %r2;
    ret;
}

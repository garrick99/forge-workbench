// Real-world shape: 8 chained FMAs.  This is the inner-loop pattern of
// many ML/HPC reductions and tests the scheduler's handling of a tight
// dependency chain (each FMA depends on the previous result) plus
// register-allocation pressure across constants.
.version 8.0
.target sm_120
.address_size 64
.visible .entry probe(.param .u64 p_out, .param .u32 n)
{
    .reg .u32 %r<4>;
    .reg .f32 %f<8>;
    .reg .u64 %rd<4>;
    .reg .pred %p0;

    mov.u32 %r0, %tid.x;
    ld.param.u32 %r1, [n];
    setp.ge.u32 %p0, %r0, %r1;
    @%p0 ret;

    cvt.rn.f32.u32 %f0, %r0;
    mov.f32 %f1, 0f3F800000;
    mov.f32 %f2, 0f3FC00000;
    mov.f32 %f3, 0f40000000;
    mov.f32 %f4, 0f3F000000;

    fma.rn.f32 %f5, %f0, %f2, %f3;
    fma.rn.f32 %f5, %f5, %f2, %f4;
    fma.rn.f32 %f5, %f5, %f3, %f2;
    fma.rn.f32 %f5, %f5, %f4, %f3;
    fma.rn.f32 %f5, %f5, %f2, %f4;
    fma.rn.f32 %f5, %f5, %f3, %f2;
    fma.rn.f32 %f5, %f5, %f4, %f3;
    fma.rn.f32 %f5, %f5, %f2, %f1;

    cvt.rzi.u32.f32 %r2, %f5;
    ld.param.u64 %rd0, [p_out];
    mul.wide.u32 %rd1, %r0, 4;
    add.u64 %rd2, %rd0, %rd1;
    cvta.to.global.u64 %rd2, %rd2;
    st.global.u32 [%rd2], %r2;
    ret;
}
